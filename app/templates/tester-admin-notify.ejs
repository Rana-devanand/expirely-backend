<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>New Tester Alert - Expirely</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Inter', Arial, sans-serif;
      background-color: #080810;
      color: #e2e8f0;
    }

    .wrapper {
      max-width: 580px;
      margin: 40px auto;
      background: #0e0e1a;
      border-radius: 20px;
      overflow: hidden;
      border: 1px solid rgba(99, 102, 241, 0.2);
      box-shadow: 0 20px 60px rgba(0,0,0,0.6);
    }

    /* ── Header ── */
    .header {
      background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #3730a3 100%);
      padding: 36px 36px 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .header::before {
      content: '';
      position: absolute;
      top: -50px; right: -50px;
      width: 180px; height: 180px;
      background: rgba(99,102,241,0.15);
      border-radius: 50%;
    }
    .header::after {
      content: '';
      position: absolute;
      bottom: -70px; left: -30px;
      width: 220px; height: 220px;
      background: rgba(99,102,241,0.10);
      border-radius: 50%;
    }

    .header-icon {
      width: 60px; height: 60px;
      background: rgba(255,255,255,0.12);
      border-radius: 18px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      font-size: 30px;
      margin-bottom: 14px;
      position: relative;
      z-index: 1;
    }

    .alert-badge {
      display: inline-block;
      background: rgba(250, 204, 21, 0.15);
      border: 1px solid rgba(250, 204, 21, 0.4);
      color: #fde68a;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 1.5px;
      text-transform: uppercase;
      padding: 4px 14px;
      border-radius: 50px;
      margin-bottom: 14px;
      position: relative;
      z-index: 1;
    }

    .header h1 {
      font-size: 26px;
      font-weight: 800;
      color: #ffffff;
      line-height: 1.3;
      position: relative;
      z-index: 1;
    }
    .header h1 span { color: #a5b4fc; }

    .header-sub {
      margin-top: 8px;
      font-size: 13px;
      color: #a5b4fc;
      position: relative;
      z-index: 1;
    }

    /* ── Body ── */
    .body {
      padding: 36px 36px 28px;
      background: #0e0e1a;
    }

    /* ── Highlight stat cards ── */
    .stat-row {
      display: flex;
      gap: 12px;
      margin-bottom: 28px;
    }
    .stat-card {
      flex: 1;
      background: #191929;
      border: 1px solid rgba(99,102,241,0.15);
      border-radius: 12px;
      padding: 16px 14px;
      text-align: center;
    }
    .stat-icon { font-size: 22px; margin-bottom: 6px; }
    .stat-value {
      font-size: 18px;
      font-weight: 800;
      color: #a5b4fc;
    }
    .stat-label {
      font-size: 11px;
      color: #64748b;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      margin-top: 2px;
    }

    /* ── User info card ── */
    .user-card {
      background: #13132a;
      border: 1px solid rgba(99,102,241,0.25);
      border-radius: 14px;
      overflow: hidden;
      margin-bottom: 24px;
    }
    .user-card-header {
      background: linear-gradient(90deg, rgba(99,102,241,0.15), transparent);
      padding: 12px 20px;
      font-size: 11px;
      font-weight: 700;
      color: #818cf8;
      text-transform: uppercase;
      letter-spacing: 1px;
      border-bottom: 1px solid rgba(99,102,241,0.1);
    }
    .user-card-body { padding: 0 20px; }
    .detail-row {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 13px 0;
      border-bottom: 1px solid rgba(255,255,255,0.04);
    }
    .detail-row:last-child { border-bottom: none; }
    .detail-icon {
      width: 32px; height: 32px;
      background: rgba(99,102,241,0.12);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 15px;
      flex-shrink: 0;
    }
    .detail-key {
      font-size: 12px;
      color: #64748b;
      flex: 1;
    }
    .detail-val {
      font-size: 13px;
      font-weight: 600;
      color: #e2e8f0;
      text-align: right;
    }

    /* ── Notes section ── */
    .notes-box {
      background: #13132a;
      border: 1px solid rgba(99,102,241,0.15);
      border-radius: 12px;
      padding: 16px 18px;
      margin-bottom: 24px;
    }
    .notes-title {
      font-size: 11px;
      font-weight: 700;
      color: #818cf8;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 8px;
    }
    .notes-text {
      font-size: 13px;
      color: #94a3b8;
      line-height: 1.65;
      font-style: italic;
    }

    /* ── Action buttons ── */
    .action-row {
      display: flex;
      gap: 12px;
      margin-bottom: 24px;
    }
    .btn-primary {
      flex: 1;
      display: inline-block;
      background: linear-gradient(135deg, #4f46e5, #7c3aed);
      color: #fff;
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      padding: 13px 16px;
      border-radius: 10px;
      text-align: center;
      box-shadow: 0 6px 20px rgba(99,102,241,0.35);
    }
    .btn-secondary {
      flex: 1;
      display: inline-block;
      background: #191929;
      border: 1px solid rgba(99,102,241,0.3);
      color: #a5b4fc;
      font-size: 13px;
      font-weight: 600;
      text-decoration: none;
      padding: 13px 16px;
      border-radius: 10px;
      text-align: center;
    }

    /* ── Info strip ── */
    .info-strip {
      background: #0b1120;
      border: 1px solid rgba(59,130,246,0.2);
      border-radius: 10px;
      padding: 12px 16px;
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }
    .info-strip-icon { font-size: 18px; }
    .info-strip-text { font-size: 12px; color: #64748b; line-height: 1.5; }
    .info-strip-text strong { color: #93c5fd; }

    /* ── Footer ── */
    .footer {
      background: #08080f;
      padding: 22px 36px;
      text-align: center;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .footer-brand { font-size: 14px; font-weight: 700; color: #818cf8; margin-bottom: 6px; }
    .footer-text  { font-size: 11px; color: #334155; line-height: 1.6; }

    .divider {
      height: 1px;
      background: linear-gradient(to right, transparent, rgba(99,102,241,0.3), transparent);
      margin: 20px 0;
    }
  </style>
</head>
<body>
  <div class="wrapper">

    <!-- Header -->
    <div class="header">
      <div class="header-icon">🔔</div>
      <div><span class="alert-badge">⚡ Admin Alert</span></div>
      <h1>New Tester <span>Just Joined!</span></h1>
      <p class="header-sub">Someone registered as a beta tester on Expirely</p>
    </div>

    <!-- Body -->
    <div class="body">

      <!-- Quick Stats -->
      <div class="stat-row">
        <div class="stat-card">
          <div class="stat-icon">👤</div>
          <div class="stat-value"><%= username %></div>
          <div class="stat-label">Username</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">📅</div>
          <div class="stat-value"><%= registeredAt %></div>
          <div class="stat-label">Registered On</div>
        </div>
        <div class="stat-card">
          <div class="stat-icon">✅</div>
          <div class="stat-value">Active</div>
          <div class="stat-label">Status</div>
        </div>
      </div>

      <!-- User Details Card -->
      <div class="user-card">
        <div class="user-card-header">🧑‍💻 Tester Details</div>
        <div class="user-card-body">
          <div class="detail-row">
            <div class="detail-icon">👤</div>
            <div class="detail-key">Full Name</div>
            <div class="detail-val"><%= username %></div>
          </div>
          <div class="detail-row">
            <div class="detail-icon">📧</div>
            <div class="detail-key">Email Address</div>
            <div class="detail-val"><%= email %></div>
          </div>
          <div class="detail-row">
            <div class="detail-icon">🕒</div>
            <div class="detail-key">Registered At</div>
            <div class="detail-val"><%= registeredAt %></div>
          </div>
        </div>
      </div>

      <% if (notes && notes.trim() !== '') { %>
      <!-- Notes -->
      <div class="notes-box">
        <div class="notes-title">📝 Tester Notes</div>
        <div class="notes-text">"<%= notes %>"</div>
      </div>
      <% } %>

      <div class="divider"></div>

      <!-- Info Strip -->
      <div class="info-strip">
        <span class="info-strip-icon">💡</span>
        <span class="info-strip-text">
          This is an <strong>automated admin notification</strong> from Expirely's backend.
          A welcome email has already been sent to the tester automatically.
        </span>
      </div>

    </div>

    <!-- Footer -->
    <div class="footer">
      <div class="footer-brand">⏳ Expirely — Admin Panel</div>
      <p class="footer-text">
        This email was sent automatically to the admin.<br/>
        &copy; <%= new Date().getFullYear() %> Expirely. All rights reserved.
      </p>
    </div>

  </div>
</body>
</html>
